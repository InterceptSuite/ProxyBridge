<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ProxyBridge.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="480"
        x:Class="ProxyBridge.GUI.Views.LogFiltersWindow"
        x:DataType="vm:LogFiltersViewModel"
        x:CompileBindings="True"
        Title="Log Filters"
        Icon="/Assets/logo.ico"
        Width="700" Height="460"
        MinWidth="560" MinHeight="300"
        Background="#FF2D2D30"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#FF1E1E1E" Padding="20,16"
                BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🔽" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="Log Filters"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FFE0E0E0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Loc.LogFiltersDesc1}"
                           FontSize="12"
                           Foreground="#FF9E9E9E"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Loc.LogFiltersDesc2}"
                           FontSize="12"
                           Foreground="#FF9E9E9E"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#FF1E1E1E" Padding="16,12"
                BorderBrush="#FF3F3F46" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,8,Auto,8,Auto">
                <Button Grid.Column="1"
                        Content="Clear All"
                        Command="{Binding ClearAllCommand}"
                        Classes="secondary"
                        Padding="12,8"/>
                <Button Grid.Column="3"
                        Content="Cancel"
                        Command="{Binding CloseCommand}"
                        Classes="secondary"
                        Padding="12,8"/>
                <Button Grid.Column="5"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="24,8"/>
            </Grid>
        </Border>

        <!-- Body -->
        <DockPanel>
            <!-- Add Rule button -->
            <Border DockPanel.Dock="Top" Background="#FF252526" Padding="16,10"
                    BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1">
                <Button Content="+ Add Rule"
                        Command="{Binding AddRuleCommand}"
                        Classes="secondary"
                        Padding="12,6"
                        HorizontalAlignment="Left"/>
            </Border>

            <!-- Rule cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Rules}" Margin="12,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LogFilterRuleViewModel">
                            <Border Background="#FF1E1E1E"
                                    BorderBrush="#FF4A4A50"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,8">
                                <StackPanel>

                                    <!-- Rule header: Mode + remove button -->
                                    <Border Background="#FF252526" Padding="12,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding ModeList}"
                                                      SelectedItem="{Binding Mode}"
                                                      MinWidth="110"
                                                      Padding="8,5"/>
                                            <Button Grid.Column="2"
                                                    Content="🗑"
                                                    Command="{Binding $parent[ItemsControl].((vm:LogFiltersViewModel)DataContext).RemoveRuleCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="secondary"
                                                    Padding="4"
                                                    Width="32" Height="32"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Fields -->
                                    <Border Padding="12,10">
                                        <Grid ColumnDefinitions="80,*,20,80,*"
                                              RowDefinitions="Auto,Auto,Auto">

                                            <!-- Row 0: Process | Action -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="Process"
                                                       Foreground="#FF9E9E9E" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,6"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding ProcessName}"
                                                     Watermark="any  (e.g. curl, chrome*, *.exe)"
                                                     Padding="8,5" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="0" Grid.Column="3"
                                                       Text="Action"
                                                       Foreground="#FF9E9E9E" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,6"/>
                                            <ComboBox Grid.Row="0" Grid.Column="4"
                                                      ItemsSource="{Binding ActionList}"
                                                      SelectedItem="{Binding Action}"
                                                      HorizontalAlignment="Stretch"
                                                      Padding="8,5" Margin="0,0,0,6"/>

                                            <!-- Row 1: IP | Protocol -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="IP"
                                                       Foreground="#FF9E9E9E" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,6"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding Ip}"
                                                     Watermark="any  (e.g. 8.8.*, 192.168.*)"
                                                     Padding="8,5" Margin="0,0,0,6"/>
                                            <TextBlock Grid.Row="1" Grid.Column="3"
                                                       Text="Protocol"
                                                       Foreground="#FF9E9E9E" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,6"/>
                                            <ComboBox Grid.Row="1" Grid.Column="4"
                                                      ItemsSource="{Binding ProtocolList}"
                                                      SelectedItem="{Binding Protocol}"
                                                      HorizontalAlignment="Stretch"
                                                      Padding="8,5" Margin="0,0,0,6"/>

                                            <!-- Row 2: Port -->
                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="Port"
                                                       Foreground="#FF9E9E9E" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding Port}"
                                                     Watermark="any  (e.g. 443, 8080)"
                                                     Padding="8,5"/>

                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </DockPanel>
</Window>
